<Window x:Class="CodexFlow.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexFlow" Width="1460" Height="940" MinWidth="1080" MinHeight="700"
        WindowStartupLocation="CenterScreen" Background="{StaticResource Paper}" WindowStyle="None"
        ResizeMode="CanResizeWithGrip">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="34" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource Ground}" MouseLeftButtonDown="TitleBar_Drag">
      <Grid>
        <TextBlock Text="CODEXFLOW  /  WINDOWS" Foreground="#67FFFFFF" FontSize="10" FontWeight="SemiBold"
                   VerticalAlignment="Center" Margin="16,0" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="—" Width="46" Foreground="#AAFFFFFF" Background="Transparent" BorderThickness="0" Click="Minimize_Click" />
          <Button Content="□" Width="46" Foreground="#AAFFFFFF" Background="Transparent" BorderThickness="0" Click="Maximize_Click" />
          <Button Content="×" Width="46" Foreground="#AAFFFFFF" Background="Transparent" BorderThickness="0" Click="Close_Click" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="234" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="{StaticResource Ground}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <StackPanel Margin="22,28,20,30">
            <StackPanel Orientation="Horizontal">
              <Border Width="42" Height="42" CornerRadius="12" Background="#13283A" BorderBrush="#335878" BorderThickness="1">
                <Grid>
                  <Ellipse Width="7" Height="7" Fill="{StaticResource SignalBright}" Margin="0,-12,0,0" />
                  <Ellipse Width="7" Height="7" Fill="{StaticResource SignalBright}" Margin="-17,11,0,0" />
                  <Ellipse Width="7" Height="7" Fill="{StaticResource SignalBright}" Margin="17,11,0,0" />
                  <Line X1="15" Y1="15" X2="27" Y2="28" Stroke="{StaticResource Signal}" StrokeThickness="1.5" />
                  <Line X1="27" Y1="15" X2="15" Y2="28" Stroke="{StaticResource Signal}" StrokeThickness="1.5" />
                </Grid>
              </Border>
              <TextBlock Text="Codex" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0" />
              <TextBlock Text="Flow" Foreground="{StaticResource SignalBright}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
          </StackPanel>
          <TextBlock Grid.Row="1" Text="WORKSPACE" Foreground="#62FFFFFF" FontSize="9" FontWeight="SemiBold" Margin="22,0,0,9" />
          <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="NavigationPanel" />
          </ScrollViewer>
          <Border Grid.Row="3" Margin="14,14,14,17" Padding="15" CornerRadius="14" Background="#0CFFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="RailStateDot" Width="8" Height="8" Fill="#70808D" VerticalAlignment="Center" />
                <StackPanel Margin="10,0,0,0">
                  <TextBlock x:Name="RailState" Text="Discovering" Foreground="#E0FFFFFF" FontWeight="SemiBold" FontSize="11" />
                  <TextBlock x:Name="RailWorkspace" Text="No project selected" Foreground="#72FFFFFF" FontSize="11" MaxWidth="155" TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </StackPanel>
              <ComboBox x:Name="RuntimePicker" Margin="0,14,0,0" SelectionChanged="RuntimePicker_SelectionChanged"
                        Background="#0EFFFFFF" Foreground="White" BorderBrush="#28FFFFFF" Padding="8" />
              <TextBlock Text="A Flow7 product" Foreground="#42FFFFFF" FontSize="9" FontWeight="SemiBold" Margin="0,15,0,0" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Grid Grid.Column="1" Background="{StaticResource Paper}">
        <Grid.RowDefinitions>
          <RowDefinition Height="80" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource Paper}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
          <Grid Margin="28,0">
            <StackPanel VerticalAlignment="Center">
              <TextBlock x:Name="HeaderWorkspace" Text="No project selected" Foreground="{StaticResource Ink}" FontWeight="SemiBold" FontSize="14" />
              <TextBlock x:Name="HeaderPath" Text="Run codexflow once to connect this app." Foreground="{StaticResource InkMuted}" FontFamily="Consolas" FontSize="11" Margin="0,3,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <Border CornerRadius="16" BorderBrush="#B8CEBF" BorderThickness="1" Background="#E7EFE9" Padding="11,7" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal"><Ellipse x:Name="HeaderStateDot" Width="8" Height="8" Fill="#70808D" Margin="0,0,8,0" /><TextBlock x:Name="HeaderState" Text="Offline" FontWeight="SemiBold" /></StackPanel>
              </Border>
              <Button Content="↻" Style="{StaticResource FlowButton}" Click="Refresh_Click" Margin="0,0,8,0" />
              <Button Content="Start" Style="{StaticResource PrimaryButton}" Click="Start_Click" Margin="0,0,8,0" />
              <Button Content="Restart" Style="{StaticResource FlowButton}" Click="Restart_Click" Margin="0,0,8,0" />
              <Button Content="Stop" Style="{StaticResource DangerButton}" Click="Stop_Click" />
            </StackPanel>
          </Grid>
        </Border>

        <Grid Grid.Row="1">
          <ScrollViewer x:Name="PageScroller" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PageContent" Margin="32,30,32,46" MaxWidth="1280" HorizontalAlignment="Stretch" />
          </ScrollViewer>
          <Border x:Name="Notice" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,24,0"
                  Background="{StaticResource PaperBright}" BorderBrush="#BCD5E5" BorderThickness="1" CornerRadius="12" Padding="16,12">
            <Grid><TextBlock x:Name="NoticeText" MaxWidth="420" TextWrapping="Wrap" Foreground="{StaticResource Ink}" Margin="0,0,28,0" /><Button Content="×" Click="DismissNotice_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" /></Grid>
          </Border>
        </Grid>
      </Grid>
    </Grid>
  </Grid>
</Window>
