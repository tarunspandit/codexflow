{
  "name": "@tarunspandit/codexflow",
  "version": "0.43.0",
  "description": "Independent one-command local coding backend that gives ChatGPT project, file, git, terminal, skill, and plugin access.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tarunspandit/codexflow.git"
  },
  "bugs": {
    "url": "https://github.com/tarunspandit/codexflow/issues"
  },
  "homepage": "https://tarunspandit.github.io/codexflow/",
  "keywords": [
    "mcp",
    "chatgpt",
    "codex",
    "apps-sdk",
    "codexflow",
    "local-development",
    "cloudflare-tunnel",
    "ngrok",
    "tailscale"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "desktop/prebuilt/CodexFlow.app",
    "desktop/macos/README.md",
    "docs",
    "scripts",
    "README.md",
    "README_ZH.md",
    "PUBLIC_LAUNCH_CHECKLIST.md",
    "DOMAIN_SETUP.md",
    "LICENSE",
    "NOTICE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "FAQ.md",
    "FAQ_ZH.md",
    "CODEX_DESKTOP_PARITY.md",
    "CHANGELOG.md",
    "CHATGPT_PROMPT.md",
    "CODEX_PROMPT.md",
    "AGENTS.example.md",
    "config.example.env"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "codexflow": "scripts/codexflow.mjs",
    "codexflow-mcp": "dist/stdio.js",
    "codexflow-mcp-http": "dist/http.js"
  },
  "scripts": {
    "build": "node scripts/clean.mjs && tsc -p tsconfig.json",
    "desktop:build": "node desktop/macos/build-app.mjs",
    "desktop:smoke": "node scripts/desktop-smoke.mjs && node scripts/native-browser-smoke.mjs",
    "prepack": "npm run build",
    "start": "node dist/stdio.js",
    "start:stdio": "node dist/stdio.js",
    "start:http": "node dist/http.js",
    "dev:stdio": "tsx src/stdio.ts",
    "dev:http": "tsx src/http.ts",
    "smoke": "node scripts/chat-routes-smoke.mjs && node scripts/runtime-monitor-smoke.mjs && node scripts/analysis-smoke.mjs && node scripts/analysis-cli-smoke.mjs && node scripts/smoke.mjs && node scripts/remote-connections-smoke.mjs && node scripts/remote-routing-smoke.mjs && node scripts/http-smoke.mjs && node scripts/review-hunks-smoke.mjs && node scripts/computer-use-smoke.mjs && node scripts/browser-use-smoke.mjs && node scripts/pro-smoke.mjs && node scripts/doctor-smoke.mjs && node scripts/settings-smoke.mjs && node scripts/cli-smoke.mjs && node scripts/desktop-smoke.mjs && node scripts/native-browser-smoke.mjs && node scripts/execute-handoff-smoke.mjs && node scripts/worktree-git-smoke.mjs && node scripts/terminal-smoke.mjs",
    "stress": "npm run build && node scripts/stress.mjs",
    "analysis:smoke": "npm run build && node scripts/analysis-smoke.mjs",
    "analysis:cli-smoke": "npm run build && node scripts/analysis-cli-smoke.mjs",
    "doctor": "node scripts/codexflow.mjs doctor",
    "connect": "node scripts/codexflow.mjs",
    "connect:local": "node scripts/codexflow.mjs --tunnel none",
    "connect:cloudflare": "node scripts/codexflow.mjs --tunnel cloudflare",
    "connect:chatgpt": "node scripts/codexflow.mjs --tunnel cloudflare",
    "connect:stable": "node scripts/codexflow.mjs --tunnel cloudflare-named",
    "connect:ngrok": "node scripts/codexflow.mjs ngrok",
    "connect:tailscale": "node scripts/codexflow.mjs tailscale",
    "pro:bundle": "node scripts/pro-bundle.mjs",
    "pro:apply": "node scripts/pro-apply.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "minimatch": "^10.0.1",
    "smol-toml": "^1.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "ajv": "^8.20.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "@hono/node-server": "^2.0.11"
  }
}
